{
  "name": "hina-beauty-glow",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise MERN beauty salon platform with security-first architecture.",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace shared && npm run build --workspace client && npm run build --workspace server",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "audit:prod": "npm audit --omit=dev",
    "security:zap": "docker compose -f docker-compose.security.yml run --rm zap",
    "security:snyk": "snyk test --all-projects",
    "sonar": "sonar-scanner"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
